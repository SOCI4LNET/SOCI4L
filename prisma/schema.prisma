// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id           String   @id @default(cuid())
  address      String   @unique
  slug         String?  @unique
  slugHash     String?  @unique // keccak256 hash of slug
  slugClaimedAt DateTime?
  owner        String?  // wallet address of the claimer (kept for backward compatibility)
  ownerAddress String?  // wallet address of the claimer
  status       String   @default("UNCLAIMED") // UNCLAIMED | CLAIMED
  visibility   String   @default("PUBLIC")   // PUBLIC | PRIVATE
  isPublic     Boolean  @default(false)       // kept for backward compatibility
  isBanned     Boolean  @default(false)
  isVerified   Boolean  @default(false)
  role         String   @default("USER")      // USER | ADMIN
  claimedAt    DateTime?
  displayName      String?  // max 32 characters

  bio              String?  // max 160 characters
  primaryRole      String?  // e.g. "Builder", "Trader"
  secondaryRoles   String[] @default([]) // e.g. ["Designer", "Collector"]
  statusMessage    String?  // e.g. "Open to collabs"
  socialLinks      String?  // JSON array of social links
  layoutConfig     String?  // JSON ProfileLayoutConfig
  appearanceConfig String?  // JSON ProfileAppearanceConfig
  premiumExpiresAt DateTime? // For Premium Payment System
  premiumLastTxHash String? // Tx hash of the last premium purchase
  createdAt        DateTime @default(now())
  updatedAt    DateTime @updatedAt

  showcase ShowcaseItem[]
  links    ProfileLink[]
  categories LinkCategory[]
  activityLogs UserActivityLog[]

  socialConnections SocialConnection[]
  
  @@index([address])
  @@index([slug])
  @@index([owner])
  @@index([ownerAddress])
  @@index([isBanned])
}

model SocialConnection {
  id              String   @id @default(cuid())
  profileId       String
  profile         Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  platform        String   // 'twitter', 'github', etc.
  platformUsername String
  platformUserId   String?
  accessToken      String? // Optional: if we need to make API calls on behalf of user
  refreshToken     String? // Optional
  verifiedAt      DateTime @default(now())
  
  @@unique([platform, platformUserId])
  @@index([profileId])
  @@index([platformUsername])
}

model UserActivityLog {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  action    String   // 'login' | 'update_profile' | 'ban' | 'unban' | ...
  metadata  String?  // JSON additional context
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([profileId])
  @@index([createdAt])
}

model ShowcaseItem {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  tokenId   String   // NFT token ID
  contractAddress String // NFT contract address
  createdAt DateTime @default(now())

  @@index([profileId])
}

model Follow {
  id              String   @id @default(cuid())
  followerAddress String   // wallet address of the follower
  followingAddress String  // wallet address being followed
  createdAt       DateTime @default(now())

  @@unique([followerAddress, followingAddress])
  @@index([followerAddress])
  @@index([followingAddress])
}

model Block {
  id              String   @id @default(cuid())
  blockerAddress  String   // wallet address of the person who is blocking
  blockedAddress  String   // wallet address of the person being blocked
  createdAt       DateTime @default(now())

  @@unique([blockerAddress, blockedAddress])
  @@index([blockerAddress])
  @@index([blockedAddress])
}

model LinkCategory {
  id          String   @id @default(cuid())
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  description String?
  order       Int      @default(0) // Order for sorting (lower = first)
  isVisible   Boolean  @default(true)
  isDefault   Boolean  @default(false) // Cannot be deleted if true
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  links ProfileLink[]

  @@unique([profileId, slug])
  @@index([profileId])
  @@index([profileId, isVisible])
}

model ProfileLink {
  id         String       @id @default(cuid())
  profileId  String
  profile    Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  categoryId String?
  category   LinkCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  title      String       @default("")
  url        String
  enabled    Boolean      @default(true)
  order      Int          @default(0) // Order for sorting (lower = first)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([profileId])
  @@index([profileId, enabled])
  @@index([categoryId])
  @@index([createdAt])
}

model EmailSubscription {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  type      String   // 'profile_view' | 'link_click'
  profileId String   // profile address (normalized lowercase)
  linkId    String?  // for link_click events
  linkTitle String?
  linkUrl   String?
  categoryId String?

  source    String   @default("unknown") // 'profile' | 'qr' | 'copy' | 'unknown'
  referrer  String?
  country   String?
  device    String?
  visitorWallet String? // Wallet address of the visitor if connected
  
  // Advanced Analytics
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  utmTerm       String?
  utmContent    String?
  isBot         Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([profileId])
  @@index([profileId, type])
  @@index([linkId])
  @@index([createdAt])
}

model ScoreSnapshot {
  id          String   @id @default(cuid())
  profileId   String   // Profile address (normalized lowercase)
  score       Float
  tier        String
  
  // Breakdown
  profileClaimed  Int   @default(0)
  displayName     Int   @default(0)
  bio             Int   @default(0)
  socialLinks     Int   @default(0)
  profileLinks    Int   @default(0)
  followers       Float @default(0)
  
  createdAt   DateTime @default(now())
  
  @@index([profileId])
  @@index([profileId, createdAt])
}

model AdminAuditLog {
  id           String   @id @default(cuid())
  adminAddress String
  action       String   // 'login' | 'view_user' | 'export_data' | ...
  targetType   String?  // 'profile' | 'link' | 'subscriber' | 'system'
  targetId     String?
  metadata     String?  // JSON additional context
  ipHash       String?  // Hashed IP for security audit (optional for now)
  createdAt    DateTime @default(now())
  
  @@index([adminAddress])
}
model Mute {
  id            String   @id @default(cuid())
  muterAddress  String   // wallet address of the person who is muting
  mutedAddress  String   // wallet address of the person being muted
  createdAt     DateTime @default(now())

  @@unique([muterAddress, mutedAddress])
  @@index([muterAddress])
  @@index([mutedAddress])
}

model UserList {
  id          String   @id @default(cuid())
  creatorAddress String // wallet address of the list creator
  name        String
  description String?
  isPrivate   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  members     UserListMember[]

  @@index([creatorAddress])
}

model UserListMember {
  id            String   @id @default(cuid())
  listId        String
  list          UserList @relation(fields: [listId], references: [id], onDelete: Cascade)
  memberAddress String   // wallet address of the user in the list
  createdAt     DateTime @default(now())

  @@unique([listId, memberAddress])
  @@index([listId])
  @@index([memberAddress])
}

// Docs Admin Panel Models

model DocsAdmin {
  id        String   @id @default(cuid())
  address   String   @unique // Wallet address
  name      String?
  role      String   @default("EDITOR") // EDITOR | SUPER_ADMIN
  createdAt DateTime @default(now())

  articles  DocsArticle[]
  
  @@index([address])
}

model DocsArticle {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  content     String   // MDX Content (TEXT type in postgres)
  category    String   @default("General")
  published   Boolean  @default(false)
  viewCount   Int      @default(0)
  
  authorId    String
  author      DocsAdmin @relation(fields: [authorId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([category])
  @@index([published])
}
// Custom Slug Registry Models

model SlugCooldown {
  id             String   @id @default(cuid())
  slug           String
  slugHash       String   @unique
  previousOwner  String   // wallet address
  releasedAt     DateTime
  cooldownEndsAt DateTime
  createdAt      DateTime @default(now())

  @@index([slugHash])
  @@index([cooldownEndsAt])
}

model IndexerState {
  key             String   @id // e.g., "slug_registry"
  lastSyncedBlock BigInt   @default(0)
  updatedAt       DateTime @updatedAt
}

model ProcessedEvent {
  id        String   @id @default(cuid())
  txHash    String
  logIndex  Int
  eventName String
  processedAt DateTime @default(now())

  @@unique([txHash, logIndex, eventName])
  @@index([txHash])
}
