DATABASE_URL=
DATABASE_URL_DEV=
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_ADMIN_ADDRESSES=
OPENSEA_API_KEY=
PRIVY_APP_SECRET=
NEXT_PUBLIC_PRIVY_APP_ID=
AUTH_SESSION_SECRET=
DOCS_ADMIN_SESSION_SECRET=
CRON_SECRET=

# Comma-separated Chrome extension IDs to allow in /api/social/lookup CORS.
# Mainnet (hpdblnjffdobbhohkjlniikdfkafagdk) and Fuji testnet
# (iacmfillllnjmfpcpoplkjkphjlpjfge) are already hardcoded in the source.
# Only needed for additional custom builds.
CHROME_EXTENSION_IDS=

# Network Configuration ('mainnet' or 'fuji')
NEXT_PUBLIC_NETWORK=mainnet

# Custom RPCs (Optional)
NEXT_PUBLIC_AVALANCHE_RPC=
NEXT_PUBLIC_FUJI_RPC=

# Fuji Smart Contract Addresses (Required if NEXT_PUBLIC_NETWORK=fuji)
NEXT_PUBLIC_FUJI_SLUG_REGISTRY_ADDRESS=
NEXT_PUBLIC_FUJI_PREMIUM_PAYMENT_ADDRESS=
NEXT_PUBLIC_FUJI_DONATE_PAYMENT_ADDRESS=